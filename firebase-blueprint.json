{
  "entities": {
    "BlindLevel": {
      "title": "BlindLevel",
      "description": "Blind Level model",
      "type": "object",
      "properties": {
        "small": { "type": "number" },
        "big": { "type": "number" },
        "ante": { "type": "number" },
        "duration": { "type": "number" },
        "tournamentId": { "type": "number" },
        "levelOrder": { "type": "number" }
      },
      "required": ["small", "big", "ante", "duration", "tournamentId", "levelOrder"]
    },
    "League": {
      "title": "League",
      "description": "Leagues - organize players and tournaments",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "isPublic": { "type": "boolean" },
        "currentSeasonName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId", "isPublic"]
    },
    "LeagueMember": {
      "title": "LeagueMember",
      "description": "League members - who can access/manage each league",
      "type": "object",
      "properties": {
        "leagueId": { "type": "number" },
        "userId": { "type": "string" },
        "role": { "type": "string" },
        "joinedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["leagueId", "userId", "role"]
    },
    "Season": {
      "title": "Season",
      "description": "Seasons - organize tournaments and player stats by time period",
      "type": "object",
      "properties": {
        "leagueId": { "type": "number" },
        "name": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "numberOfGames": { "type": "number" },
        "status": { "type": "string" },
        "pointsSystemConfig": { "type": "object" },
        "settings": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["leagueId", "name", "startDate", "endDate", "numberOfGames", "status"]
    },
    "LeaguePlayer": {
      "title": "LeaguePlayer",
      "description": "League players - the actual poker players with statistics",
      "type": "object",
      "properties": {
        "leagueId": { "type": "number" },
        "seasonId": { "type": "number" },
        "name": { "type": "string" },
        "totalPoints": { "type": "number" },
        "gamesPlayed": { "type": "number" },
        "knockouts": { "type": "number" },
        "firstPlaces": { "type": "number" },
        "secondPlaces": { "type": "number" },
        "thirdPlaces": { "type": "number" },
        "finalTableAppearances": { "type": "number" },
        "totalWinnings": { "type": "number" },
        "totalBuyIns": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["leagueId", "seasonId", "name", "totalPoints", "gamesPlayed", "knockouts", "firstPlaces", "secondPlaces", "thirdPlaces", "finalTableAppearances", "totalWinnings", "totalBuyIns"]
    },
    "TournamentResult": {
      "title": "TournamentResult",
      "description": "Tournament results - individual tournament performance",
      "type": "object",
      "properties": {
        "leagueId": { "type": "number" },
        "seasonId": { "type": "number" },
        "leaguePlayerId": { "type": "number" },
        "tournamentDate": { "type": "string", "format": "date-time" },
        "tournamentName": { "type": "string" },
        "position": { "type": "number" },
        "totalPlayers": { "type": "number" },
        "points": { "type": "number" },
        "knockouts": { "type": "number" },
        "prizeMoney": { "type": "number" },
        "buyIn": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["leagueId", "seasonId", "leaguePlayerId", "tournamentDate", "position", "totalPlayers"]
    },
    "ActiveTournament": {
      "title": "ActiveTournament",
      "description": "Active tournaments table for real-time tournament management",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "currentLevel": { "type": "number" },
        "secondsLeft": { "type": "number" },
        "isRunning": { "type": "boolean" },
        "participantCode": { "type": "string" },
        "directorCode": { "type": "string" },
        "buyIn": { "type": "number" },
        "blindLevels": { "type": "array" },
        "settings": { "type": "object" },
        "prizeStructure": { "type": "object" },
        "players": { "type": "array" },
        "status": { "type": "string" },
        "lastDirectorHeartbeat": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "directorCode", "blindLevels", "settings", "prizeStructure"]
    },
    "LeagueSettings": {
      "title": "LeagueSettings",
      "description": "League settings",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "settings": { "type": "object" },
        "isDefault": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "settings", "isDefault"]
    },
    "TournamentTemplate": {
      "title": "TournamentTemplate",
      "description": "Saved tournament templates for users",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "blindLevels": { "type": "array" },
        "prizeStructure": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId", "blindLevels", "prizeStructure"]
    }
  },
  "firestore": {
    "blindLevels": {
      "schema": "BlindLevel",
      "description": "Blind Level model"
    },
    "leagues": {
      "schema": "League",
      "description": "Leagues - organize players and tournaments"
    },
    "seasons": {
      "schema": "Season",
      "description": "Seasons - organize tournaments and player stats by time period"
    },
    "leaguePlayers": {
      "schema": "LeaguePlayer",
      "description": "League players - the actual poker players with statistics"
    },
    "tournamentResults": {
      "schema": "TournamentResult",
      "description": "Tournament results - individual tournament performance"
    },
    "activeTournaments": {
      "schema": "ActiveTournament",
      "description": "Active tournaments table for real-time tournament management"
    },
    "leagueSettings": {
      "schema": "LeagueSettings",
      "description": "League settings"
    },
    "tournamentTemplates": {
      "schema": "TournamentTemplate",
      "description": "Saved tournament templates for users"
    }
  }
}
