rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: leagues
    // Fields:
    //   - name: string
    //   - description: string
    //   - ownerId: string
    //
    // Collection: seasons
    // Fields:
    //   - leagueId: string
    //   - name: string
    //   - startDate: timestamp
    //   - endDate: timestamp
    //
    // Collection: leaguePlayers
    // Fields:
    //   - leagueId: string
    //   - seasonId: string
    //   - name: string
    //   - totalPoints: number
    //   - gamesPlayed: number
    //   - knockouts: number
    //   - firstPlaces: number
    //   - secondPlaces: number
    //   - thirdPlaces: number
    //   - finalTableAppearances: number
    //   - totalWinnings: number
    //   - totalBuyIns: number
    //
    // Collection: tournamentResults
    // Fields:
    //   - leagueId: string
    //   - seasonId: string
    //   - leaguePlayerId: string
    //   - tournamentDate: timestamp
    //   - tournamentName: string
    //   - position: number
    //   - totalPlayers: number
    //   - points: number
    //   - knockouts: number
    //   - prizeMoney: number
    //   - buyIn: number
    //
    // Collection: activeTournaments
    // Fields:
    //   - name: string
    //   - ownerId: string
    //   - transferCode: string
    //   - transferCodeExpiresAt: number
    //   - transferCodeGeneratedBy: string
    //   - status: string
    //   - currentLevel: number
    //   - secondsLeft: number
    //   - isRunning: boolean
    //   - players: list
    //   - blindLevels: list
    //   - settings: map
    //   - prizeStructure: map
    //
    // Collection: leagueSettings
    // Fields:
    //   - leagueId: string
    //   - userId: string
    //   - settings: map
    //
    // ===============================================================

    // Helper Functions
    // Note: anonymous Firebase auth users count as authenticated (request.auth != null)
    // This is intentional — players scan QR codes and get anonymous auth to view/interact
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAnonymous() {
      return isAuthenticated() && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    function isRegistered() {
      return isAuthenticated() && !isAnonymous();
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
    }

    function isExistingDocOwner() {
      return isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    function isDocUser() {
      return isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    function isExistingDocUser() {
      return isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    // User Settings
    match /userSettings/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Leagues — registered users only (not anonymous)
    match /leagues/{leagueId} {
      allow read: if isRegistered();
      allow create: if isRegistered() && isDocOwner()
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() < 100;
      allow update: if isRegistered() && isExistingDocOwner()
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() < 100;
      allow delete: if isRegistered() && isExistingDocOwner();
    }

    // League Members
    match /leagueMembers/{memberId} {
      allow read: if isRegistered();
      allow create: if isRegistered();
      allow update: if isRegistered();
      allow delete: if isRegistered();
    }

    // Seasons — registered users only
    match /seasons/{seasonId} {
      allow read: if isRegistered();
      allow create: if isRegistered();
      allow update: if isRegistered();
      allow delete: if isRegistered();
    }

    // League Players
    match /leaguePlayers/{playerId} {
      allow read: if isRegistered();
      allow create: if isRegistered();
      allow update: if isRegistered();
      allow delete: if isRegistered();
    }

    // Tournament Results
    match /tournamentResults/{resultId} {
      allow read: if isRegistered();
      allow create: if isRegistered();
      allow update: if isRegistered();
      allow delete: if isRegistered();
    }

    // Active Tournaments
    // - Anyone can read — players scan a QR code; no login required to view
    // - Only registered owner can create
    // - Owner can update anything
    // - Any authenticated user can claim a seat (players array only) — QR check-in
    // - Transfer code update allowed only for the recipient becoming the new owner
    match /activeTournaments/{tournamentId} {
      allow read: if true;
      allow create: if isRegistered() && isDocOwner();
      allow update: if isAuthenticated() && (
        // Owner can change anything
        isExistingDocOwner() ||
        // Participants can only claim a seat (players array) or update timer state
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['players', 'currentLevel', 'secondsLeft', 'isRunning', 'notes',
                    'transferCode', 'transferCodeExpiresAt', 'transferCodeGeneratedBy', 'ownerId'])
      );
      allow delete: if isRegistered() && isExistingDocOwner();
    }

    // League Settings — registered users only, scoped to their own settings
    match /leagueSettings/{settingId} {
      allow read: if isRegistered() && resource.data.userId == request.auth.uid;
      allow create: if isRegistered() && isDocUser();
      allow update: if isRegistered() && isExistingDocUser()
        && request.resource.data.userId == resource.data.userId;
      allow delete: if isRegistered() && isExistingDocUser();
    }

    // Tournament Templates — owner only
    match /tournamentTemplates/{templateId} {
      allow read: if isRegistered() && resource.data.ownerId == request.auth.uid;
      allow create: if isRegistered() && isDocOwner();
      allow update: if isRegistered() && isExistingDocOwner() && isDocOwner();
      allow delete: if isRegistered() && isExistingDocOwner();
    }
  }
}
