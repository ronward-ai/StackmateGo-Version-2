rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAnonymous() {
      return isAuthenticated() && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    function isRegistered() {
      return isAuthenticated() && !isAnonymous();
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
    }

    function isExistingDocOwner() {
      return isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    function isDocUser() {
      return isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    function isExistingDocUser() {
      return isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Cross-document league ownership check (used for season/player/result scoping)
    function ownsLeague(leagueId) {
      return isRegistered() &&
        get(/databases/$(database)/documents/leagues/$(leagueId)).data.ownerId == request.auth.uid;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    // User Settings
    match /userSettings/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Leagues
    match /leagues/{leagueId} {
      allow read: if isAuthenticated();
      allow create: if isRegistered() && isDocOwner()
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() < 100;
      allow update: if isRegistered() && isExistingDocOwner()
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() < 100;
      allow delete: if isRegistered() && isExistingDocOwner();
    }

    // Seasons — readable by any authenticated user (includes anonymous QR participants)
    match /seasons/{seasonId} {
      allow read: if isAuthenticated();
      allow create: if isRegistered() && request.resource.data.leagueId is string;
      allow update: if ownsLeague(resource.data.leagueId);
      allow delete: if ownsLeague(resource.data.leagueId);
    }

    // League Players — readable by any authenticated user
    match /leaguePlayers/{playerId} {
      allow read: if isAuthenticated();
      allow create: if isRegistered() && request.resource.data.leagueId is string;
      allow update: if ownsLeague(resource.data.leagueId);
      allow delete: if ownsLeague(resource.data.leagueId);
    }

    // Tournament Results — readable by any authenticated user
    match /tournamentResults/{resultId} {
      allow read: if isAuthenticated();
      allow create: if isRegistered() && request.resource.data.leagueId is string;
      allow update: if ownsLeague(resource.data.leagueId);
      allow delete: if ownsLeague(resource.data.leagueId);
    }

    // Active Tournaments
    // - Any authenticated user can read (anonymous QR participants included)
    // - Only a registered owner can create
    // - Owner can change anything
    // - Authenticated non-owners can update a restricted set of fields (timer/players/transfer)
    //   but cannot change ownerId — that would allow privilege escalation
    match /activeTournaments/{tournamentId} {
      allow read: if isAuthenticated();
      allow create: if isRegistered() && isDocOwner();
      allow update: if (
        // Owner can change anything
        isAuthenticated() && isExistingDocOwner()
      ) || (
        // Authenticated participants can update timer/player/transfer fields only.
        // ownerId is intentionally excluded to prevent privilege escalation.
        isAuthenticated() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['players', 'currentLevel', 'secondsLeft', 'isRunning', 'notes',
                    'targetEndTime', 'smallBlind', 'bigBlind', 'ante', 'blindLevels',
                    'transferCode', 'transferCodeExpiresAt', 'transferCodeGeneratedBy'])
      );
      allow delete: if isRegistered() && isExistingDocOwner();
    }

    // League Settings — registered users only, scoped to their own settings
    match /leagueSettings/{settingId} {
      allow read: if isRegistered() && resource.data.userId == request.auth.uid;
      allow create: if isRegistered() && isDocUser();
      allow update: if isRegistered() && isExistingDocUser()
        && request.resource.data.userId == resource.data.userId;
      allow delete: if isRegistered() && isExistingDocUser();
    }

    // Tournament Templates — owner only
    match /tournamentTemplates/{templateId} {
      allow read: if isRegistered() && resource.data.ownerId == request.auth.uid;
      allow create: if isRegistered() && isDocOwner();
      allow update: if isRegistered() && isExistingDocOwner() && isDocOwner();
      allow delete: if isRegistered() && isExistingDocOwner();
    }
  }
}
